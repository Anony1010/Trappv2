<!doctype html>
<html lang="az">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="robots" content="noindex,nofollow">
<title></title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#000}
.full{position:fixed;inset:0;width:100%;height:100%;border:0;object-fit:cover;background:#000}
</style>
</head>
<body>
<% if (file.type === 'image') { %>
<img class="full" src="/raw/<%= file.id %>" alt="">
<% } else if (file.type === 'video') { %>
<video id="v" class="full" src="/raw/<%= file.id %>" autoplay playsinline loop></video>
<script>
const v=document.getElementById('v');
v.muted=false;
v.volume=1;
const p=v.play();
if(p&&p.catch)p.catch(()=>{});
</script>
<% } else { %>
<iframe class="full" src="/raw/<%= file.id %>" allow="camera; microphone; geolocation; autoplay; fullscreen"></iframe>
<% } %>
</body>
</html>